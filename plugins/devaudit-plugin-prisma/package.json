{
  "name": "@metasession.co/devaudit-plugin-prisma",
  "version": "0.1.37",
  "description": "Prisma migration deploy hooks + status commands for DevAudit-onboarded node consumers.",
  "type": "module",
  "main": "./dist/plugin.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@metasession.co/devaudit-plugin-sdk": "file:../../plugin-sdk",
    "execa": "^9.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  },
  "devaudit": {
    "apiVersion": "1",
    "displayName": "Prisma helper",
    "description": "Prisma migration deploy hooks for Node consumers",
    "commands": [
      {
        "name": "migrate-status",
        "description": "Show pending Prisma migrations via `npx prisma migrate status`"
      },
      {
        "name": "pending",
        "description": "List migration directories under prisma/migrations/"
      }
    ],
    "hooks": [
      "afterUpdate",
      "onDoctor"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/metasession-dev/DevAudit-Installer",
    "directory": "plugins/devaudit-plugin-prisma"
  },
  "license": "Apache-2.0"
}
